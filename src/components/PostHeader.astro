---
import PageHeader from "@/components/PageHeader.astro";

interface Props {
  title: string;
  published: Date;
  readTime: string;
  tags?: string[];
}

const { title, published, readTime, tags } = Astro.props;

const formattedDate = published.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<PageHeader {title}>
  <div slot="meta" class="post-meta">
    <time datetime={published.toISOString()}>{formattedDate}</time>
    <span aria-hidden="true">·</span>
    <span>{readTime}</span>
    {tags && tags.length > 0 && (
      <span aria-hidden="true">·</span>
      <div class="post-tags" aria-label="Tags">
        {tags.map((tag) => (
          <a href={`/tags/${tag}`} class="post-tag">{tag}</a>
        ))}
      </div>
    )}
  </div>
</PageHeader>

<style>
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tag {
    color: var(--foreground-subtle);
    text-decoration: none;

    &::before { content: "#"; }
    &::after  { content: none !important; }

    &:hover {
      color: var(--foreground);
      opacity: 1;
    }
  }
</style>