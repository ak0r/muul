---
import { join } from "node:path";
import "@pagefind/default-ui/css/ui.css";

const bundlePath = join(import.meta.env.BASE_URL, "pagefind/");
---

<div
  data-pagefind-ui
  data-bundle-path={bundlePath}
  class="search-wrap"
></div>

<script>
  import { PagefindUI } from "@pagefind/default-ui";

  window.addEventListener("DOMContentLoaded", () => {
    const allSelector = "[data-pagefind-ui]";

    for (const el of document.querySelectorAll(allSelector)) {
      const elSelector = [
        ...(el.id ? [`#${el.id}`] : []),
        ...[...el.classList.values()].map((c) => `.${c}`),
        allSelector,
      ].join("");

      const bundlePath = el.getAttribute("data-bundle-path");

      new PagefindUI({
        element: elSelector,
        bundlePath,
        showImages: false,
        debounceTimeoutMs: 100,
        resetStyles: true,
        excerptLength: 25,
      });

      const input = el.querySelector("input[type=\"text\"]");
      input?.focus();

      // Restore query from URL on load
      const params = new URLSearchParams(window.location.search);
      const query = params.get("q");
      if (query && input) {
        input.value = query;
        input.dispatchEvent(new Event("input", { bubbles: true }));
      }

      // Sync query to URL as user types
      input?.addEventListener("input", (e) => {
        const val = e.target.value;
        const url = new URL(window.location.href);
        const params = new URLSearchParams(url.search);
        if (val) {
          params.set("q", val);
        } else {
          params.delete("q");
        }
        window.history.replaceState({}, "", `${url.pathname}${params.size ? "?" + params : ""}`);
      });
    }
  });
</script>

<style>
  .search-wrap {
    max-width: var(--article-max);
  }

  /* Pagefind UI token overrides */
  [data-pagefind-ui] {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary:       var(--accent);
    --pagefind-ui-text:          var(--foreground);
    --pagefind-ui-background:    var(--background);
    --pagefind-ui-border:        var(--border);
    --pagefind-ui-border-width:  1px;
    --pagefind-ui-border-radius: var(--radius);
    --pagefind-ui-tag:           var(--background-subtle);
    --pagefind-ui-font:          var(--font-primary);
  }
</style>