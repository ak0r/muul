---
interface Props {
  title: string;
  pagefind?: boolean;
}

const { title, pagefind = false } = Astro.props;
---

<header class="page-header">
  <h1 data-pagefind-meta={pagefind ? "title" : ""}>{title}</h1>
  {Astro.slots.has('meta') && (
    <div class="page-header-meta">
      <slot name="meta" />
    </div>
  )}
</header>

<style>
  .page-header {
    margin-bottom: var(--space-10);
  }

  .page-header-meta {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--foreground-subtle);
  }
</style>