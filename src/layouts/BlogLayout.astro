---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SEO from "@/components/SEO.astro";
import PageHeader from "@/components/PageHeader.astro";
import SeriesNav from "@/components/SeriesNav.astro";
import {
  getPublishedPosts,
  getSeriesPosts,
  getRelatedPosts,
  calculateReadingTime,
} from "@/utils/content.utils";
import { siteConfig } from "@/site.config";

interface Props {
  entry: CollectionEntry<"posts">;
}

const { entry } = Astro.props;
const { title, description, published, tags, cover, series } = entry.data;

const allPosts = await getPublishedPosts();
const related = getRelatedPosts(entry, allPosts, siteConfig.relatedPosts);
const seriesPosts = series ? await getSeriesPosts(series) : [];
const readTime = calculateReadingTime(entry.body ?? "").text;

const formattedDate = published.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout>
  <SEO
    slot="seo"
    {title}
    description={description ?? ""}
    type="article"
    publishedTime={published}
    {tags}
    image={cover}
  />

  <PageHeader slot="header" {title}>
    <div slot="meta" class="post-meta">
      <time datetime={published.toISOString()}>{formattedDate}</time>
      <span aria-hidden="true">·</span>
      <span>{readTime}</span>
      {tags && tags.length > 0 && (
        <>
          <span aria-hidden="true">·</span>
          <div class="post-tags" aria-label="Tags">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="post-tag">{tag}</a>
            ))}
          </div>
        </>
      )}
    </div>
  </PageHeader>

  <Fragment slot="content">
    <meta data-pagefind-meta="title[content]" content={title} />
    <meta data-pagefind-sort="date[content]" content={published.toISOString()} />
    <meta data-pagefind-filter="collection[content]" content="posts" />
    {tags && tags.map((tag) => (
      <meta data-pagefind-filter="tag[content]" content={tag} />
    ))}

    {cover && (
      <figure class="post-cover">
        <img src={cover} alt={title} />
      </figure>
    )}

    <section class="post-content">
      <slot />
    </section>
  </Fragment>

  <Fragment slot="navigation">
    {seriesPosts.length > 1 && (
      <SeriesNav current={entry} posts={seriesPosts} />
    )}
  </Fragment>

  <Fragment slot="after">
    {related.length > 0 && (
      <aside class="related-posts">
        <h2>Related</h2>
        <ul>
          {related.map((post) => (
            <li>
              <a href={`/posts/${post.id}`}>{post.data.title}</a>
              <time datetime={post.data.published.toISOString()}>
                {post.data.published.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </Fragment>
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-tag {
    color: var(--foreground-subtle);
    text-decoration: none;

    &::before { content: "#"; }
    &::after  { content: none !important; }

    &:hover {
      color: var(--foreground);
      opacity: 1;
    }
  }

  .post-cover {
    margin-bottom: var(--space-8);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .post-cover img {
    width: 100%;
    display: block;
  }

  .post-content {
    margin-bottom: var(--space-10);
  }

  .related-posts {
    border-top: 1px solid var(--border);
    padding-top: var(--space-8);
    margin-top: var(--space-8);
  }

  .related-posts h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .related-posts ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .related-posts li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .related-posts a::after {
    content: none !important;
  }

  .related-posts time {
    color: var(--foreground-subtle);
    font-size: var(--text-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>