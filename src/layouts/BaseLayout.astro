---

/**
 * BaseLayout — shared structural scaffold for all content pages.
 *
 * Slots:
 *   header     — page title, meta (PageHeader)
 *   content    — main content, wrapped in <article data-pagefind-body>
 *   navigation — contextual navigation (SeriesNav, prev/next, breadcrumbs)
 *   after      — supplementary content (related posts, comments)
 *
 * Used by BlogLayout and PageLayout. Forks can use it directly
 * for new layout types without touching Muul's wrapper layouts.
 */

import Head from "@/components/Head.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <Head>
    <slot name="seo" slot="seo" />
    <slot name="head" slot="head" />
  </Head>
  <body>
    <Header />

    <main>
      <!-- Structured content layouts — container owned here -->
      <div class="container">
        <slot name="header" />

        <article data-pagefind-body>
          <slot name="content" />
        </article>

        <slot name="navigation" />
        <slot name="after" />
      </div>

      <!-- Default slot — for pages that manage their own layout (index, search, 404) -->
      <slot />
    </main>

    <Footer />

    <slot name="scripts" />
  </body>
</html>