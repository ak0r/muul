---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SEO from "@/components/SEO.astro";
import PostList from "@/components/PostList.astro";
import { siteConfig } from "@/site.config";
import { getPublishedPosts } from "@/utils/content.utils";

const homeEntry = await getEntry("pages", "home");
const { Content } = await render(homeEntry);

const allPosts = await getPublishedPosts();
const recent = allPosts.slice(0, siteConfig.recentPosts);
---

<BaseLayout>
  <SEO slot="seo" title="Home" description={siteConfig.description} />

  <div class="container">
    <h1 class="sr-only">{siteConfig.title}</h1>

    <section class="home-intro" data-pagefind-ignore>
      <Content />
    </section>

    <section class="home-posts">
      <h2 class="home-posts-heading">Recent</h2>
      <PostList posts={recent} />
    </section>
  </div>
</BaseLayout>

<style>
  .home-intro {
    margin-bottom: var(--space-12);
  }

  .home-posts-heading {
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--foreground-subtle);
    margin-bottom: var(--space-6);
    margin-block-start: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--text-xs);
  }
</style>